# ----------------------------------------------------------------------------
# Copy this file to `.env.local` for local development, or `.env` for Docker:
#   cp .env.example .env.local
# Only NEXT_PUBLIC_* variables are exposed to the browser.
# ----------------------------------------------------------------------------

# Base URL of the backend API (NestJS). Consumed by the typed API client.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Public application name (optional; defaults to "PNC Journey Star").
NEXT_PUBLIC_APP_NAME="PNC Journey Star"
